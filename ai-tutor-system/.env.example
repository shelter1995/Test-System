# ============================================================
#  AI Tutor System — 环境变量配置模板
#  复制此文件为 .env 并填写你的密钥
# ============================================================

# 统一模型设置由 8003 知识库服务管理；请在前端「模型设置」页面配置 LLM/Embedding/Rerank。
RAG_SERVICE_URL=http://localhost:8003
RAG_REQUEST_TIMEOUT=90
DEFAULT_RAG_DATABASE=

# 内容生成任务并发数
GENERATION_MAX_RUNNING_JOBS=1

# Tutor 服务
TUTOR_SERVICE_HOST=0.0.0.0
TUTOR_SERVICE_PORT=8002
