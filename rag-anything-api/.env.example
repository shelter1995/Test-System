# ============================================================
#  RAG-Anything 智能检索系统 — 环境变量配置模板
#  复制此文件为 .env 并填写你的密钥
# ============================================================

# ===== MiniMax LLM（文本生成 + 实体抽取） =====
MINIMAX_API_KEY=sk-your-minimax-key-here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL_M27=MiniMax-M2.7
MINIMAX_MODEL_M25=MiniMax-M2.5

# ===== MiniMax Coding Plan VLM（图片理解 / 多模态查询） =====
# 使用 MiniMax Coding Plan 专用 VLM 接口 /v1/coding_plan/vlm
# 注意：需要 MiniMax Coding Plan 套餐（M2.1 及以上）
ENABLE_VLM=false
# VLM_API_KEY 留空自动复用 MINIMAX_API_KEY
VLM_API_KEY=
# 国内站: https://api.minimaxi.com  国际站: https://api.minimax.io
VLM_BASE_URL=https://api.minimaxi.com
# coding_plan 接口不需要指定模型名
VLM_MODEL=

# ===== 硅基流动 Embedding（文本转向量） =====
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn
SILICONFLOW_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_MAX_TOKENS=5000

# ===== 硅基流动 Rerank（检索结果重排序） =====
# 开启后查询结果会经过重排序，提升相关性
ENABLE_RERANK=false
# RERANK_API_KEY 留空自动复用 SILICONFLOW_API_KEY
RERANK_API_KEY=
RERANK_BASE_URL=https://api.siliconflow.cn
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ===== 查询配置 =====
# 用户可见知识库统一使用传统 RAG（向量检索 + 重排）。
# 历史 RAG-Anything 数据仅用于兼容读取，不作为前端可切换引擎。
# 可选: naive（纯向量）, local（局部图谱）, global（全局图谱）,
#       hybrid（向量+图谱融合）, mix（自动混合）
DEFAULT_QUERY_MODE=hybrid

# ===== 多库并发查询超时（秒） =====
QUERY_ALL_TIMEOUT=60

# ===== 轻量上下文检索 =====
CONTEXT_QUERY_MODE=naive
CONTEXT_MAX_CHARS=3000
CONTEXT_LOCAL_FIRST=true

# ===== 知识库问答检索 =====
KB_QUERY_REWRITE_ENABLED=true
KB_RETRIEVAL_CANDIDATES=20
KB_FINAL_CONTEXTS=8
KB_MIN_SCORE=0.25
KB_MAX_REWRITE_QUERIES=3

# ===== MinerU 文档解析 =====
PARSER=mineru
PARSE_METHOD=auto
# Mineru 后端: pipeline（默认）或 vlm（需要 GPU）
MINERU_BACKEND=pipeline

# ===== 多模态处理开关 =====
ENABLE_IMAGE_PROCESSING=true
ENABLE_TABLE_PROCESSING=true
ENABLE_EQUATION_PROCESSING=true
ENABLE_VIDEO_PROCESSING=false
ENABLE_AUDIO_PROCESSING=false

# ===== 分块配置 =====
CHUNK_SIZE=1200
CHUNK_OVERLAP_SIZE=100

# ===== 传统 RAG 引擎 =====
DEFAULT_RAG_ENGINE=traditional
TRADITIONAL_SUPPORTED_EXTENSIONS=.txt,.md,.csv,.pdf,.docx,.xlsx,.pptx,.doc,.xls,.ppt,.png,.jpg,.jpeg,.bmp,.tiff,.tif,.webp,.mp3,.wav,.m4a,.aac,.flac,.ogg,.wma,.mp4,.mov,.mkv,.avi,.wmv,.webm,.m4v
TRADITIONAL_CHUNK_SIZE=1200
TRADITIONAL_CHUNK_OVERLAP=120
EMBEDDING_BATCH_SIZE=10
EMBEDDING_BATCH_INTERVAL=1.0
EMBEDDING_RETRY_ATTEMPTS=3
EMBEDDING_RETRY_BASE_DELAY=30

# ===== 服务配置 =====
RAG_SERVICE_HOST=0.0.0.0
RAG_SERVICE_PORT=8003

# ===== 超时配置（秒） =====
LLM_TIMEOUT_M27=120
LLM_TIMEOUT_M25=90
EMBEDDING_TIMEOUT=30

# ===== 其他 =====
MAX_RAG_INSTANCES=3
HF_ENDPOINT=
LIBREOFFICE_PATH=
MINERU_CLI_PATH=
